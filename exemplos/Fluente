# SISTEMA SIMPLES
def cadastro():
    banco = []

    for i in range(2):
        nome = input("Nome: ")
        idade = int(input("Idade: "))

        pessoa = {
            "nome": nome,
            "idade": idade
        }

        banco.append(pessoa)

    return banco

def listar(dados):
    for p in dados:
        print(f"{p['nome']} - {p['idade']} anos")

usuarios = cadastro()
listar(usuarios)

print("Fim fluente")