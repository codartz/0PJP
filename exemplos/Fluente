# CLASSE
class Pessoa:
    def __init__(self, nome, idade):
        self.nome = nome
        self.idade = idade

    def mostrar(self):
        print(self.nome, self.idade)

p1 = Pessoa("Maria", 25)
p1.mostrar()

# HERANÇA
class Aluno(Pessoa):
    def __init__(self, nome, idade, curso):
        super().__init__(nome, idade)
        self.curso = curso

    def mostrar_curso(self):
        print(self.nome, self.curso)

aluno = Aluno("João", 20, "Python")
aluno.mostrar_curso()

